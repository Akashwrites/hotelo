<!DOCTYPE html>
<html>
<head>
    <title>All Listings</title>
</head>
<body>
    

<h1>All Listings</h1>
    <form action="/listings/new" method="GET">
        <button> create New Listing</button>
    </form>

<ul>
    <% for(let listing of allListings){ %>
        <li>
            <a href="/listings/<%= listing._id %>">
                <%= listing.title %>
            </a>
        </li>
    <% } %>
</ul>


</body>
</html>